APP_NAME=NUERS
APP_ENV=production
APP_KEY=base64:REPLACE_WITH_YOUR_EXISTING_APP_KEY
APP_DEBUG=false
APP_URL=https://nuers.net
APP_TIMEZONE=Asia/Manila

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=sqlite
# Leave DB_DATABASE unset so Laravel uses database/database.sqlite in this project.

CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

VITE_APP_NAME="${APP_NAME}"
